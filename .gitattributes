* -text

# C/C++
*.c             linguist-language=C
*.h             linguist-language=C

# assembler-with-cpp
*.S             linguist-language=Assembly
*.sx            linguist-language=Assembly

# dvp-gas assembly
*.dsm           linguist-language=Assembly
*.vsm           linguist-language=Assembly
*.vcl           linguist-language=Assembly

# Makefile
*.mkf           linguist-language=Makefile
Makefile.*      linguist-language=Makefile
MakeDefs        linguist-language=Makefile
MakeRules       linguist-language=Makefile
PathDefs        linguist-language=Makefile

# Scripts
*.sh            text eol=lf
*.bash          text eol=lf
*.fish          text eol=lf
*.csh           text eol=lf
*.tcsh          text eol=lf
*.ksh           text eol=lf
*.zsh           text eol=lf

*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Vim
*.vim           text eol=lf
.vimrc          text eol=lf
.gvimrc         text eol=lf

# Visual Studio Code
# Fix syntax highlighting on GitHub to allow comments
.vscode/*.json  linguist-language=JSON-with-Comments

# Visual Studio
*.sln           text eol=crlf
*.csproj        text eol=crlf
*.vbproj        text eol=crlf
*.vcxproj       text eol=crlf
*.vcproj        text eol=crlf
*.dbproj        text eol=crlf
*.fsproj        text eol=crlf
*.lsproj        text eol=crlf
*.wixproj       text eol=crlf
*.modelproj     text eol=crlf
*.sqlproj       text eol=crlf
*.wwaproj       text eol=crlf

*.xproj         text eol=crlf
*.props         text eol=crlf
*.filters       text eol=crlf
*.vcxitems      text eol=crlf

# Visual Studio 6.0
*.dsp           text eol=crlf
*.dsw           text eol=crlf
mssccprj.scc    text eol=crlf
vssver.scc      binary
