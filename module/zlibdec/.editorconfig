#
# .editorconfig for zlibdec 1.1.3 (for PlayStation 2)
#
# zlib data compression library version 1.1.3 (July 9th, 1998)
# Copyright (C) 1995-1998 Jean-loup Gailly and Mark Adler
#
root = false

[*.{c,h}]
tab_width       = 8
indent_size     = 4
indent_style    = unset
end_of_line     = unset
charset         = unset

max_line_length = off
trim_trailing_whitespace = false
insert_final_newline = unset
